{
  "name": "grpc-server",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "author": "Ajit Kumar",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "build": "tsc",
    "generate": "protoc --plugin=protoc-gen-ts_proto=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=./src/generated --ts_proto_opt=outputServices=grpc-js,env=node ./proto/banking.proto",
    "start": "node dist/server.js",
    "dev": "tsc --watch & node --watch dist/server.js"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "ts-node": "^10.9.2",
    "ts-proto": "^2.11.6",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "express": "^5.2.1"
  }
}
